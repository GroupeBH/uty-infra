{% if domain_name | default('') | length > 0 %}
{% if caddy_email | default('') | length > 0 %}
{
  email {{ caddy_email }}
}
{% endif %}
{{ domain_name }} {
  encode zstd gzip
  reverse_proxy app:{{ app_port }}{% for peer_ip in app_peer_private_ips | default([]) %} {{ peer_ip }}:{{ app_port }}{% endfor %} {
    lb_policy round_robin
    lb_try_duration 5s
    lb_try_interval 250ms
    health_uri {{ app_healthcheck_path }}
    health_interval 10s
    health_timeout 2s
  }
}
{% else %}
:80 {
  encode zstd gzip
  reverse_proxy app:{{ app_port }}{% for peer_ip in app_peer_private_ips | default([]) %} {{ peer_ip }}:{{ app_port }}{% endfor %} {
    lb_policy round_robin
    lb_try_duration 5s
    lb_try_interval 250ms
    health_uri {{ app_healthcheck_path }}
    health_interval 10s
    health_timeout 2s
  }
}
{% endif %}
