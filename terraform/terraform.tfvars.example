aws_region = "us-east-1"

availability_zone            = "us-east-1a"
secondary_availability_zone  = ""
vpc_cidr                     = "10.0.0.0/16"
public_subnet_cidr           = "10.0.1.0/24"
secondary_public_subnet_cidr = "10.0.2.0/24"

ami_id = ""

instance_type              = "t3.micro"
secondary_instance_enabled = true
instance_name              = "uty-api"

key_name   = "my-ec2-keypair"
admin_cidr = "198.51.100.10/32"

domain_name = "api.example.com"
caddy_email = "ops@example.com"

app_image_repository = "dockerhub-user/uty-api"
app_image_tag        = "latest"
app_healthcheck_path = "/health"

log_retention_days    = 14
alarm_email_endpoints = ["ops@example.com"]

ssm_secure_parameters = {
  "/uty/prod/JWT_SECRET" = "replace-me"
}